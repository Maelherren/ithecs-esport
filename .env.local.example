# =====================================================================
#  ITHECS — Variables d'environnement
#  Copie ce fichier en `.env.local` et remplis les valeurs.
# =====================================================================

# --- Supabase (Project Settings > API) ---
# URL publique du projet Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co

# Clé "anon / public" — sûre côté client, protégée par les policies RLS
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Clé "service_role" — SECRÈTE, uniquement côté serveur.
# NE JAMAIS préfixer avec NEXT_PUBLIC_ et NE JAMAIS l'exposer au client.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- Authentification ---
# Secret utilisé pour signer les sessions (JWT httpOnly).
# Génère une valeur longue et aléatoire, ex :
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=change-me-with-a-long-random-string

# --- Emails automatiques (Resend) ---
# Clé API Resend (https://resend.com > API Keys). Requise pour l'alerte
# « 3 présents » sur le Calendrier Matcherino.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# (Optionnel) Expéditeur. Par défaut : "ITHECS <onboarding@resend.dev>"
# (adresse de test qui n'écrit qu'au propriétaire du compte Resend).
# Pour envoyer à n'importe qui, vérifie un domaine sur Resend puis mets p.ex. :
#   RESEND_FROM=ITHECS <alertes@ton-domaine.com>
# RESEND_FROM=ITHECS <onboarding@resend.dev>

# (Optionnel) Destinataire des alertes. Par défaut : mael.herren@icloud.com
# ALERT_EMAIL=mael.herren@icloud.com

# --- Web Push (notifications mobile) ---
# Génère les clés avec : npx web-push generate-vapid-keys
# La clé publique DOIT être préfixée NEXT_PUBLIC_ (lisible côté navigateur).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_EMAIL=mael.herren@icloud.com
